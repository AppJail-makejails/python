build:
  variants:
    - tag: %%TAG1%%
      containerfile: Containerfile.pkg
      aliases: ["latest"]
      default: true
      args:
        FREEBSD_RELEASE: "%%TAG1%%"
    - tag: %%TAG1%%-3
      containerfile: Containerfile.pkg
      args:
        FREEBSD_RELEASE: "%%TAG1%%"
        PYTHON_VERSION: "3"
