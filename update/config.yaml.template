      args:
        FREEBSD_RELEASE: "%%TAG1%%"
        PYTHON_VERSION: "27"
    - tag: %%TAG1%%-310
      containerfile: Containerfile.pkg
      args:
        FREEBSD_RELEASE: "%%TAG1%%"
        PYTHON_VERSION: "310"
    - tag: %%TAG1%%-311
      containerfile: Containerfile.pkg
      args:
        FREEBSD_RELEASE: "%%TAG1%%"
        PYTHON_VERSION: "311"
    - tag: %%TAG1%%-312
      containerfile: Containerfile.pkg
      args:
        FREEBSD_RELEASE: "%%TAG1%%"
        PYTHON_VERSION: "312"
    - tag: %%TAG1%%-313
      containerfile: Containerfile.pkg
      args:
        FREEBSD_RELEASE: "%%TAG1%%"
